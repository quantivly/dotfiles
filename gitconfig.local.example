# Personal Git Configuration
# This file is sourced by ~/.gitconfig and should contain your personal settings.
# Copy this to ~/.gitconfig.local and customize it.
#
# DO NOT commit ~/.gitconfig.local to git - it contains personal information!

[user]
	name = Your Name
	email = your.email@quantivly.com

# Work/Personal Routing (DUAL-IDENTITY PROFILE — commented out by default)
# ------------------------------------------------------------------------
# If you keep a personal AND a work identity on this machine, set your PERSONAL
# identity in the [user] block above, then conditionally include a work identity
# for any repo that belongs to the quantivly org. Routing is git-native and
# authoritative regardless of shell state OR the repo's on-disk path.
#
# The signal is the repo's REMOTE (its GitHub org), via hasconfig — so a work
# repo routes correctly even when checked out outside ~/quantivly/ (e.g. Atrium
# worktrees under ~/.atrium/worktrees/, or /tmp clones). Requires git >= 2.36
# (check with `git --version`); on older git the conditions are silently ignored
# and work repos fall back to the personal identity above.
#
# To enable: set the [user] block above to your PERSONAL identity, create
# ~/.gitconfig-work from ~/.dotfiles/gitconfig-work.example, and uncomment the
# three rules below (all include the same work file; the three forms cover the
# SSH, HTTPS, and github-work host-alias remote URLs):
#
# [includeIf "hasconfig:remote.*.url:git@github.com:quantivly/**"]
#     path = ~/.gitconfig-work
# [includeIf "hasconfig:remote.*.url:https://github.com/quantivly/**"]
#     path = ~/.gitconfig-work
# [includeIf "hasconfig:remote.*.url:git@github-work:quantivly/**"]
#     path = ~/.gitconfig-work
#
# dev-setup's dual profile (modules/accounts.sh) wires this up automatically.
# On a WORK-ONLY box, leave this commented and set the work identity directly
# in the [user] block above (the whole machine is work — nothing to route).

# Commit Signing with SSH (Recommended)
# Signing your commits helps verify your identity and is strongly encouraged.
# SSH signing (Git 2.34+) is simpler than GPG and integrates with SSH agent workflows.
#
# Setup steps (5 minutes):
# 1. Get your SSH public key:
#    - File-based: cat ~/.ssh/id_ed25519.pub
#    - Bitwarden: ssh-add -L
#
# 2. Create allowed signers file:
#    mkdir -p ~/.ssh
#    echo "your.email@quantivly.com $(cat ~/.ssh/id_ed25519.pub)" > ~/.ssh/allowedSigners
#
# 3. Add your SSH public key to GitHub as a "Signing Key":
#    https://github.com/settings/keys (select "Signing Key" type)
#
# 4. Uncomment and configure the lines below:
#
# [user]
# 	signingkey = ssh-ed25519 AAAAC3Nza... your.email@quantivly.com
#
# [commit]
# 	gpgsign = true
#
# [gpg]
# 	format = ssh
#
# [gpg "ssh"]
# 	allowedSignersFile = ~/.ssh/allowedSigners
#
# Need help? See: ~/.dotfiles/docs/SSH_SIGNING_SETUP.md
#
# Quick test after setup:
#   git commit --allow-empty -m "Test SSH signing"
#   git log --show-signature -1  # Should show "Good 'git' signature with ED25519 key..."
#
# Daily usage:
#   Just commit normally - signing is automatic via ssh-agent!
#   (No cache priming needed unlike GPG)

# Safe Directory Configuration (Recommended)
# Prevents Git from polluting your tracked gitconfig with safe.directory entries.
# This is particularly important when running tests or working in temporary directories.
#
# Check your Git version: git --version
# Git 2.35.2+ supports wildcard patterns. Recommended approach:
[safe]
    directory = ~/*
    directory = /tmp/*
#
# Or be more specific for Quantivly development (more secure):
# [safe]
#     directory = ~/platform/*      # Q_DEV_CODE_ROOT
#     directory = ~/hub/*            # Q_HUB_ROOT
#     directory = ~/workspaces/*     # Workspaces
#     directory = ~/quanticli        # Quanticli repo
#     directory = ~/quantivly/*      # Quantivly repos
#     directory = ~/.dotfiles        # Personal dotfiles
#     directory = /tmp/*             # Test directories
#
# Alternative (most permissive - trusts all directories):
# [safe]
#     directory = *
#
# For older Git versions (no wildcards - list each directory individually):
# [safe]
#     directory = ~/.dotfiles
#     directory = ~/platform/auto-conf
#     directory = ~/platform/sre-core
#     directory = ~/hub/sre-customers-library
#     directory = ~/workspaces/dev
#     directory = ~/quanticli

# Machine-specific git configuration
# Add any other personal git settings here
